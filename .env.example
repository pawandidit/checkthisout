# Financial ML Configuration

# Data Provider
# Options: "yfinance" (default), "polygon", "iex", "tradier"
DATA_PROVIDER=yfinance

# Slack Alerting (optional)
# Get webhook from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# MLflow Tracking (optional)
# Local: ./mlruns or /path/to/mlruns
# Remote: http://mlflow-server:5000
MLFLOW_TRACKING_URI=./mlruns

# Dashboard Configuration
DASH_HOST=0.0.0.0
DASH_PORT=8050
DASH_DEBUG=True

# Market Data
YFINANCE_TIMEOUT=30
MARKET_DATA_CACHE_TTL=300

# Trading Configuration
MAX_TICKERS=5
DEFAULT_LOOKBACK_PERIOD=1y
DEFAULT_OPTION_DAYS_TO_EXPIRY=30

# Analysis
VOLATILITY_CLUSTERS=3
PROBABILITY_SIMULATIONS=2000
RANDOM_SEED=42

# Risk Management
MAX_LEVERAGE=2.0
POSITION_SIZE_PCT=2.0
STOP_LOSS_PCTS=0.7
TAKE_PROFIT_PCTS=1.6

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
